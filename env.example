# ── Gym Reminder (FREE — no account required for 1 SMS/day) ────────────────
GYM_PHONE=+15551234567          # Your mobile number with country code
GYM_REMINDER_TIMES=12:00,23:00  # UTC times HH:MM, comma-separated
TEXTBELT_KEY=textbelt            # Free key = 1 SMS/day; buy credits at textbelt.com for $0.01/text
GEMINI_API_KEY=                  # Optional: AI messages — free at aistudio.google.com (1500 req/day)

# ── Shift Reminder (Twilio + Paycor — existing feature) ────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+15550000000
PAYCOR_CLIENT_ID=your_client_id
PAYCOR_CLIENT_SECRET=your_client_secret
PAYCOR_SUBSCRIPTION_KEY=your_apim_key
PAYCOR_LEGAL_ENTITY_ID=your_legal_entity_id
APP_URL=https://your-site.netlify.app
MANAGER_PHONE=+15559990001
